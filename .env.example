# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Configuration
VITE_APP_NAME=LOCAGAME
VITE_APP_URL=https://www.locagame.net

# Demo Mode (set to 'true' only in development)
# WARNING: Never enable in production
VITE_ENABLE_DEMO_MODE=false
# Demo credentials — leave empty in production, set only in .env.local for dev
VITE_DEMO_ADMIN_EMAIL=
VITE_DEMO_ADMIN_PASSWORD=
VITE_DEMO_CLIENT_EMAIL=
VITE_DEMO_CLIENT_PASSWORD=
VITE_DEMO_TECH_EMAIL=
VITE_DEMO_TECH_PASSWORD=

# Optional: Analytics, Payment, etc.
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_STRIPE_PUBLIC_KEY=

# Sentry (error tracking) — only active in production
VITE_SENTRY_DSN=
